<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<AnchorPane prefHeight="762.0" prefWidth="1000.0" style="-fx-background-color: #f8fafc;" stylesheets="@../design/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.liamtseva.warehousemanagementsystem.presentation.controller.ProductController">
  <children>
    <VBox spacing="24.0" AnchorPane.bottomAnchor="24.0" AnchorPane.leftAnchor="24.0" AnchorPane.rightAnchor="24.0" AnchorPane.topAnchor="24.0">
      <children>
          <HBox alignment="CENTER_LEFT" spacing="16.0">
          <children>
            <VBox spacing="4.0">
              <children>
                <Label styleClass="section-title" text="Управління товарами" />
                <Label styleClass="section-subtitle" text="Ведення каталогу товарів, налаштування цін та мінімальних запасів" />
              </children>
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="addButton" onAction="#openAddDialog" prefHeight="48.0" styleClass="editorial-primary-btn" text="Додати товар" textFill="WHITE">
                <graphic>
                    <FontIcon iconColor="WHITE" iconLiteral="fas-plus" />
                </graphic>
                <font>
                    <Font name="Segoe UI Bold" size="14.0" />
                </font>
            </Button>
          </children>
        </HBox>

          <VBox spacing="20.0" VBox.vgrow="ALWAYS">
          <children>
              <VBox spacing="16.0" styleClass="card" VBox.vgrow="ALWAYS">
              <padding>
                <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
              </padding>
              <children>
                  <HBox spacing="16.0" alignment="CENTER_LEFT">
                      <children>
                          <HBox styleClass="table-search-group" HBox.hgrow="ALWAYS">
                              <children>
                                  <FontIcon iconColor="#ea580c" iconLiteral="fas-search" iconSize="16" />
                                  <TextField fx:id="searchField"
                                             promptText="Пошук за SKU або назвою..."
                                             HBox.hgrow="ALWAYS"
                                             styleClass="table-search-field" />
                                  <Separator orientation="VERTICAL" />
                                  <ComboBox fx:id="categoryFilter"
                                            prefWidth="180.0"
                                            promptText="Всі категорії"
                                            styleClass="filter-combo-box" />
                              </children>
                          </HBox>
                          <HBox spacing="8.0">
                              <children>
                                  <Button fx:id="editButton" onAction="#openEditDialog" prefHeight="42.0" prefWidth="120.0" styleClass="editorial-secondary-btn, btn-secondary-muted" text="Оновити">
                                      <graphic>
                                          <FontIcon iconColor="#64748b" iconLiteral="fas-edit" />
                                      </graphic>
                                  </Button>
                                  <Button fx:id="deleteButton" onAction="#deleteProduct" prefHeight="42.0" prefWidth="120.0" styleClass="editorial-secondary-btn, btn-secondary-muted" text="Видалити">
                                      <graphic>
                                          <FontIcon iconColor="#64748b" iconLiteral="fas-trash-alt" />
                                      </graphic>
                                  </Button>
                              </children>
                          </HBox>
                      </children>
                  </HBox>

                <TableView fx:id="productTable" prefHeight="400.0" styleClass="orders-table, modern-table" VBox.vgrow="ALWAYS">
                  <columns>
                    <TableColumn fx:id="skuColumn" prefWidth="100.0" text="SKU" />
                    <TableColumn fx:id="nameColumn" prefWidth="200.0" text="Назва" />
                    <TableColumn fx:id="categoryColumn" prefWidth="150.0" text="Категорія" />
                    <TableColumn fx:id="supplierColumn" prefWidth="150.0" text="Постачальник" />
                    <TableColumn fx:id="priceColumn" prefWidth="100.0" text="Ціна" />
                    <TableColumn fx:id="unitColumn" prefWidth="100.0" text="Од. вим." />
                    <TableColumn fx:id="minStockColumn" prefWidth="120.0" text="Мін. запас" />
                  </columns>
                  <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                  </columnResizePolicy>
                </TableView>
              </children>
            </VBox>
          </children>
        </VBox>
      </children>
    </VBox>
  </children>
</AnchorPane>

