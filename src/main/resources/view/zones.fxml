<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<AnchorPane prefHeight="762.0" prefWidth="1000.0" style="-fx-background-color: #f8fafc;" stylesheets="@../design/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.liamtseva.warehousemanagementsystem.presentation.controller.ZoneController">
  <children>
    <VBox spacing="32.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="30.0">
      <children>
        <!-- Header Section -->
        <HBox alignment="CENTER_LEFT" spacing="16.0">
          <children>
            <VBox spacing="4.0">
              <children>
                <Label styleClass="section-title" text="Управління зонами складу" />
                <Label style="-fx-text-fill: #64748b; -fx-font-size: 14px;" text="Створення, редагування та моніторинг складських зон" />
              </children>
            </VBox>
          </children>
        </HBox>

        <!-- Main Content: Form and Table -->
        <VBox spacing="24.0" VBox.vgrow="ALWAYS">
          <children>
            <!-- Input Form Card -->
            <VBox spacing="24.0" styleClass="card">
              <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
              </padding>
              <children>
                <GridPane hgap="32.0" vgap="20.0">
                  <columnConstraints>
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                  </columnConstraints>
                  <rowConstraints>
                    <RowConstraints vgrow="SOMETIMES" />
                  </rowConstraints>
                  <children>
                    <VBox spacing="10.0">
                      <children>
                        <Label styleClass="field-label" text="Назва зони" />
                        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="search-field-container" style="-fx-background-color: #f1f5f9; -fx-background-radius: 12px; -fx-padding: 2px 16px;">
                          <children>
                            <FontIcon iconColor="#64748b" iconLiteral="fas-tag" iconSize="16" />
                            <TextField fx:id="nameField" prefHeight="45.0" promptText="Наприклад: Сектор А-1" style="-fx-background-color: transparent; -fx-padding: 0;" HBox.hgrow="ALWAYS" />
                          </children>
                        </HBox>
                      </children>
                    </VBox>
                    <VBox spacing="10.0" GridPane.columnIndex="1">
                      <children>
                        <Label styleClass="field-label" text="Тип призначення" />
                        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="search-field-container" style="-fx-background-color: #f1f5f9; -fx-background-radius: 12px; -fx-padding: 2px 16px;">
                          <children>
                            <FontIcon iconColor="#64748b" iconLiteral="fas-info-circle" iconSize="16" />
                            <ComboBox fx:id="zoneTypeComboBox" maxWidth="1.7976931348623157E308" prefHeight="45.0" promptText="Оберіть тип..." style="-fx-background-color: transparent; -fx-padding: 0;" HBox.hgrow="ALWAYS" />
                          </children>
                        </HBox>
                      </children>
                    </VBox>
                  </children>
                </GridPane>

                <HBox alignment="CENTER_RIGHT" spacing="12.0">
                  <children>
                    <Button fx:id="clearButton" prefHeight="45.0" prefWidth="130.0" styleClass="editorial-secondary-btn" style="-fx-text-fill: #64748b; -fx-border-color: #e2e8f0;" text="Очистити">
                      <graphic>
                        <FontIcon iconColor="#64748b" iconLiteral="fas-broom" />
                      </graphic>
                    </Button>
                    <Button fx:id="deleteButton" prefHeight="45.0" prefWidth="130.0" styleClass="editorial-secondary-btn" style="-fx-text-fill: #64748b; -fx-border-color: #e2e8f0;" text="Видалити">
                      <graphic>
                        <FontIcon iconColor="#64748b" iconLiteral="fas-trash-alt" />
                      </graphic>
                    </Button>
                    <Button fx:id="editButton" prefHeight="45.0" prefWidth="130.0" styleClass="editorial-secondary-btn" style="-fx-text-fill: #64748b; -fx-border-color: #e2e8f0;" text="Оновити">
                      <graphic>
                        <FontIcon iconColor="#64748b" iconLiteral="fas-edit" />
                      </graphic>
                    </Button>
                    <Button fx:id="addButton" prefHeight="45.0" prefWidth="180.0" styleClass="editorial-primary-btn" text="Зберегти зону" textFill="WHITE">
                      <graphic>
                        <FontIcon iconColor="WHITE" iconLiteral="fas-plus" />
                      </graphic>
                      <font>
                        <Font name="Segoe UI Bold" size="14.0" />
                      </font>
                    </Button>
                  </children>
                </HBox>
              </children>
            </VBox>

            <!-- Table Card -->
            <VBox spacing="20.0" styleClass="card" VBox.vgrow="ALWAYS">
              <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
              </padding>
              <children>
                  <HBox alignment="CENTER_LEFT" spacing="12.0" style="-fx-background-color: #f1f5f9; -fx-background-radius: 10px; -fx-padding: 6px 16px;">
                      <children>
                          <FontIcon iconColor="#ea580c" iconLiteral="fas-search" iconSize="18" />
                          <TextField fx:id="searchField"
                                     promptText="Пошук..."
                                     HBox.hgrow="ALWAYS"
                                     style="-fx-background-color: transparent; -fx-font-size: 14px; -fx-min-height: 30px; -fx-padding: 0;" />
                      </children>
                  </HBox>

                <TableView fx:id="zoneTable" prefHeight="400.0" styleClass="orders-table" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-color: #f1f5f9; -fx-border-radius: 12px; -fx-background-radius: 12px;">
                  <columns>
                    <TableColumn fx:id="nameColumn" prefWidth="446.0" text="Назва зони" />
                    <TableColumn fx:id="typeColumn" prefWidth="446.0" text="Тип призначення" />
                  </columns>
                  <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                  </columnResizePolicy>
                </TableView>
              </children>
            </VBox>
          </children>
        </VBox>
      </children>
    </VBox>
  </children>
</AnchorPane>
