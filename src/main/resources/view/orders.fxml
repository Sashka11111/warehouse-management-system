<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="762.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.liamtseva.warehousemanagementsystem.presentation.controller.OrderController">
  <children>
    <AnchorPane layoutX="14.0" layoutY="14.0" prefHeight="200.0" prefWidth="972.0" style="-fx-background-color: transparent; -fx-border-color: #2f3479; -fx-border-radius: 8;">
      <children>
        <Label layoutX="20.0" layoutY="25.0" text="Статус замовлення:">
          <font>
            <Font name="Georgia" size="14.0" />
          </font>
        </Label>
        <ComboBox fx:id="statusComboBox" layoutX="170.0" layoutY="20.0" prefHeight="30.0" prefWidth="250.0" />

        <Button fx:id="updateStatusButton" layoutX="440.0" layoutY="20.0" prefHeight="30.0" prefWidth="150.0" styleClass="side-btn" stylesheets="@../design/style.css" text="Оновити статус" textFill="WHITE" />
        <Button fx:id="deleteButton" layoutX="600.0" layoutY="20.0" prefHeight="30.0" prefWidth="120.0" styleClass="side-btn" stylesheets="@../design/style.css" text="Видалити" textFill="WHITE" />
        
        <Label layoutX="20.0" layoutY="80.0" text="Деталі замовлення (товари будуть тут)">
          <font>
            <Font name="Georgia" size="14.0" />
          </font>
        </Label>
      </children>
    </AnchorPane>

    <HBox layoutX="100.0" layoutY="230.0" prefHeight="45.0" prefWidth="800.0" style="-fx-background-radius: 40; -fx-padding: 4; -fx-border-color: #2f3479; -fx-border-radius: 40;">
      <children>
        <TextField fx:id="searchField" prefHeight="35.0" prefWidth="750.0" promptText="Пошук замовлень за ID або користувачем..." style="-fx-background-color: transparent;" />
        <Button mnemonicParsing="false" prefHeight="35.0" prefWidth="40.0" style="-fx-background-color: #2f3479; -fx-background-radius: 20;">
          <graphic>
            <ImageView fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true">
              <image>
                <Image url="@../data/search.png" />
              </image>
            </ImageView>
          </graphic>
        </Button>
      </children>
    </HBox>

    <TableView fx:id="orderTable" layoutX="14.0" layoutY="290.0" prefHeight="450.0" prefWidth="972.0" styleClass="orders-table" stylesheets="@../design/style.css">
      <columns>
        <TableColumn fx:id="idColumn" prefWidth="250.0" text="ID Замовлення" />
        <TableColumn fx:id="userColumn" prefWidth="200.0" text="Користувач" />
        <TableColumn fx:id="dateColumn" prefWidth="180.0" text="Дата" />
        <TableColumn fx:id="statusColumn" prefWidth="150.0" text="Статус" />
        <TableColumn fx:id="amountColumn" prefWidth="150.0" text="Сума" />
      </columns>
    </TableView>
  </children>
</AnchorPane>
