           <Button layoutX="40.0" layoutY="155.0" onAction="#handleOkAction" prefHeight="45.0" prefWidth="320.0" styleClass="editorial-primary-btn" stylesheets="@../design/style.css" text="ЗРОЗУМІЛО" textFill="WHITE">
