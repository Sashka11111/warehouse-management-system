<AnchorPane prefHeight="260.0" prefWidth="440.0" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.liamtseva.warehousemanagementsystem.presentation.controller.AlertController">
  <children>
    <AnchorPane layoutX="20.0" layoutY="20.0" prefHeight="220.0" prefWidth="400.0" style="-fx-background-color: #ffffff; -fx-background-radius: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 20, 0, 0, 10);">
